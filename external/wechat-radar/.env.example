# Optional. Defaults to ~/.wechat-radar
WECHAT_RADAR_DATA_DIR=

# Comma-separated names used to detect messages that mention you.
# Example: WECHAT_RADAR_MY_NAMES=张三,San Zhang,zhangsan
WECHAT_RADAR_MY_NAMES=

# Use demo data when decrypted WeChat DB data is unavailable. Set to 1 to enable.
WECHAT_RADAR_DEMO=0

# Data source. Defaults to decrypted DB adapter; set to wx only to use legacy wx-cli/wx-daemon.
WECHAT_RADAR_DATA_SOURCE=db

# Legacy wx-cli/wx-daemon mode is ignored unless this is set to 1.
# Keep this at 0 for customer packaging.
WECHAT_RADAR_ALLOW_LEGACY_WX=0

# Hermes wechat-assistant outputs. Defaults to ~/wechat-assistant.
WECHAT_RADAR_WECHAT_ASSISTANT_DIR=
WECHAT_RADAR_COLLECTOR_DB=
WECHAT_RADAR_DECRYPTED_DIR=

# Optional. Used only when falling back from collector.db to raw decrypted message_*.db.
WECHAT_RADAR_SELF_WXID=

# Optional model name used by Codex CLI based topic/link summarization.
WECHAT_RADAR_CODEX_MODEL=

# Optional. /lab LLM provider. For GLM/OpenAI-compatible endpoints:
# WECHAT_RADAR_LAB_PROVIDER=openai-compatible
# WECHAT_RADAR_LAB_BASE_URL=https://example.com/v4
# WECHAT_RADAR_LAB_API_KEY=your_api_key_here
# WECHAT_RADAR_LAB_MODEL=glm-4-flash
WECHAT_RADAR_LAB_PROVIDER=
WECHAT_RADAR_LAB_BASE_URL=
WECHAT_RADAR_LAB_API_KEY=
WECHAT_RADAR_LAB_MODEL=

# Non-local LLM analysis can receive sampled chat content.
# Keep this at 0 unless the user explicitly accepts data egress.
WECHAT_RADAR_ALLOW_LLM_EGRESS=0

# Optional. Tune Codex CLI aggregation.
WECHAT_RADAR_TOPIC_CHUNK_SIZE=250
WECHAT_RADAR_CODEX_TIMEOUT_MS=300000
WECHAT_RADAR_LINK_CODEX_TIMEOUT_MS=180000
WECHAT_RADAR_AUTO_TOPIC_DAYS=31
